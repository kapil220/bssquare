<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect old links to new ones (301 Permanent Redirect)
  RewriteRule ^about-us/?$ /about [R=301,L]
  RewriteRule ^hr-services/?$ /services/hr-services [R=301,L]
  RewriteRule ^cad-bim/?$ /services/cad-bim [R=301,L]

  # SPA Routing
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
